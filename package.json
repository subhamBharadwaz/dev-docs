{
  "name": "dev-docs-monorepo",
  "private": true,
  "packageManager": "pnpm@11.3.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "cli": "pnpm --filter cli start",
    "chat": "pnpm --filter cli start chat",
    "ingest": "pnpm --filter cli start ingest",
    "evaluate": "pnpm --filter cli start evaluate",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "chroma": "pnpm --filter cli chroma",
    "test": "pnpm -r test"
  },
  "dependencies": {
    "@chroma-core/default-embed": "^0.1.9",
    "zod": "^4.4.3"
  }
}
